{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Edit",
      "Write",
      "MultiEdit",
      "WebFetch",
      "WebSearch",
      "LS",
      "Glob",
      "Grep",
      "NotebookRead",
      "NotebookEdit",
      "TodoWrite",
      "mcp__ide__getDiagnostics"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -rf /*)",
      "Bash(sudo rm *)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Bash(git rebase*)",
      "Bash(git stash*)",
      "Bash(git checkout*)",
      "Bash(chmod 777 *)",
      "Bash(chown *)",
      "Bash(sudo *)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(mkfs*)",
      "Bash(dd if=*)",
      "Bash(shutdown*)",
      "Bash(reboot*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enableAllProjectMcpServers": true
}
